# ───────────────────────────────────────────────────────────────
# 应用商店封面图批量生成 — 环境变量示例
#
# 用法：复制本文件为 .env，然后填入真实值
#   cp .env.example .env
#
# 注意：.env 已在 .gitignore 中，不会被 git 追踪
# ───────────────────────────────────────────────────────────────

# ── 必填 ────────────────────────────────────────────────────────
# Packy API 密钥（兼容 OpenAI 协议）
# 申请地址：https://www.packyapi.com
PACKY_API_KEY=sk-your_real_key_here

# ── 可选 ────────────────────────────────────────────────────────
# API Base URL（不改使用默认值）
# PACKY_BASE=https://www.packyapi.com/v1

# 图像模型（不改使用默认值 gpt-image-2）
# PACKY_MODEL=gpt-image-2
